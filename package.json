{
    "name": "adios-use-case-builder",
    "version": "0.1.0",
    "description": "AdiOS Use Case Builder — dual-mode (online portal + offline workshop)",
    "private": true,
    "type": "module",
    "scripts": {
          "dev": "vite",
          "build": "tsc && vite build",
          "preview": "vite preview",
          "start": "node server/index.js",
          "start:dev": "concurrently \"npm run dev\" \"npm run server:dev\"",
          "server:dev": "nodemon --watch server --ext ts,js --exec \"tsx server/index.ts\"",
          "test": "vitest",
          "test:e2e": "playwright test",
          "seed": "tsx scripts/seed-data.ts",
          "export": "tsx scripts/export-workshop.ts",
          "lint": "eslint src --ext ts,tsx",
          "typecheck": "tsc --noEmit"
    },
    "dependencies": {
          "@xyflow/react": "^12.0.0",
          "axios": "^1.6.0",
          "express": "^4.18.0",
          "open": "^10.0.0",
          "react": "^18.3.0",
          "react-dom": "^18.3.0",
          "react-router-dom": "^6.22.0",
          "zustand": "^4.5.0"
    },
    "devDependencies": {
          "@playwright/test": "^1.43.0",
          "@types/express": "^4.17.0",
          "@types/node": "^20.0.0",
          "@types/react": "^18.3.0",
          "@types/react-dom": "^18.3.0",
          "@vitejs/plugin-react": "^4.2.0",
          "concurrently": "^8.2.0",
          "nodemon": "^3.1.0",
          "tsx": "^4.7.0",
          "typescript": "^5.4.0",
          "vite": "^5.2.0",
          "vitest": "^1.5.0"
    },
    "engines": {
          "node": ">=18.0.0"
    },
    "keywords": [
          "adios",
          "use-case-builder",
          "sovereign-ai",
          "india"
    ],
    "author": "AdiOS Platform Private Limited <contact@adiosplat.io>",
    "homepage": "https://adiosplat.io"
}
