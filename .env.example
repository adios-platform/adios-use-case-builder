# AdiOS Use Case Builder — Environment Variables
# Copy to .env and fill in values

# ─── Mode ─────────────────────────────────────────────────────────────────────
# "auto"    → detect online/offline at runtime (recommended)
# "online"  → force online mode (requires gateway)
# "offline" → force offline/workshop mode (uses seed data)
VITE_UCB_MODE=auto

# ─── AdiOS Gateway ────────────────────────────────────────────────────────────
VITE_GATEWAY_URL=https://api.adiosplat.io
VITE_GATEWAY_WS_URL=wss://api.adiosplat.io/ws

# ─── Auth (OIDC) ──────────────────────────────────────────────────────────────
VITE_OIDC_CLIENT_ID=
VITE_OIDC_AUTHORITY=https://auth.adiosplat.io
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback

# ─── Storylane (Online Demo Mode) ─────────────────────────────────────────────
# Get your demo ID from app.storylane.io → Demos → Share → Embed
VITE_STORYLANE_DEMO_URL=https://app.storylane.io/demo/YOUR_DEMO_ID
VITE_STORYLANE_TEAM_ID=

# ─── Offline Workshop Mode ────────────────────────────────────────────────────
# Port for the local Express server
UCB_SERVER_PORT=3000
# Where to persist local session data
UCB_LOCAL_STORE_PATH=~/.adios-ucb/local-store.json
# Open browser automatically on npm start
UCB_AUTO_OPEN_BROWSER=true

# ─── Feature Flags ────────────────────────────────────────────────────────────
VITE_FEATURE_CORTEX_RECOMMENDATIONS=true
VITE_FEATURE_LINEAGE_PANEL=true
VITE_FEATURE_PORTFOLIO_MATRIX=true
VITE_FEATURE_GUIDED_TOUR=true
